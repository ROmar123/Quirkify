# Yoco Payment Integration
YOCO_SECRET_KEY=sk_live_YOUR_SECRET_KEY
YOCO_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# The Courier Guy API
COURIER_GUY_API_KEY=YOUR_API_KEY

# Firebase Admin SDK (for webhook payment processing)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Gemini AI (product analysis)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Yoco Payments (client-side)
VITE_YOCO_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# Supabase (backend source of truth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Environment
NODE_ENV=production
