# ===========================================
# QUIRKIFY — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# ===========================================

# --- Supabase (Public — safe for frontend) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key

# --- Supabase (PRIVATE — backend only, NOT in frontend) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase project ref (e.g. "abcdefghijklmnopqrst") — used by admin API for auto-migration
SUPABASE_PROJECT_REF=your_supabase_project_ref

# Supabase Management API personal access token — used by admin API to auto-create the campaigns table
SUPABASE_ACCESS_TOKEN=your_supabase_pat

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# --- Yoco Payments (PRIVATE — backend only) ---
YOCO_PUBLIC_KEY=your_yoco_public_key
YOCO_SECRET_KEY=your_yoco_secret_key

# --- Email — Resend (PRIVATE — backend only) ---
# Required for order confirmation and auction-winner emails to be sent
RESEND_API_KEY=your_resend_api_key
QUIRKIFY_FROM_EMAIL=noreply@yourdomain.com

# --- Mapbox (Public — address autocomplete in Checkout) ---
# Without this, the address search field returns no suggestions (silent failure)
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# --- Firebase Admin (PRIVATE — backend only) ---
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- Firebase (Public — Firestore / Storage) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# --- Courier Guy Shipping ---
TCG_API_KEY=your_tcg_api_key

# Warehouse / collection address for live TCG shipping quotes
TCG_COLLECTION_STREET=your_warehouse_street
TCG_COLLECTION_SUBURB=your_warehouse_suburb
TCG_COLLECTION_CITY=Johannesburg
TCG_COLLECTION_POSTAL=2194
TCG_COLLECTION_ZONE=GAU
TCG_COLLECTION_LAT=-26.1234
TCG_COLLECTION_LNG=28.1234
# Set to "true" once the address was entered in TCG portal for rate accuracy
TCG_COLLECTION_ENTERED=false

# --- Social Webhooks ---
# WhatsApp Business API webhook verification token (set the same value in Meta Developer Console)
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
# WhatsApp App Secret for signature verification
WHATSAPP_APP_SECRET=your_whatsapp_app_secret
# TikTok webhook secret for signature verification
TIKTOK_WEBHOOK_SECRET=your_tiktok_webhook_secret

# --- Internal API Security ---
# Shared HMAC secret for internal service-to-service calls (e.g. auction-winner-notify)
INTERNAL_API_SECRET=your_random_32_char_secret

# --- Admin emails (comma-separated) ---
VITE_ADMIN_EMAILS=admin@example.com

# --- App ---
APP_URL=https://quirkify.co.za
NODE_ENV=production
