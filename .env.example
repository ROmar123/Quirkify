# ===========================================
# QUIRKIFY — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# ===========================================

# --- Supabase (Public — safe for frontend) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase (PRIVATE — backend only, NOT in frontend) ---
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# --- Yoco Payments (PRIVATE — backend only) ---
YOCO_PUBLIC_KEY=your_yoco_public_key
YOCO_SECRET_KEY=your_yoco_secret_key

# --- Firebase Admin (PRIVATE — backend only) ---
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- Courier Guy (Private) ---
COURIER_GUY_API_KEY=your_courier_guy_api_key

# --- Email Notifications (Private — via Resend) ---
RESEND_API_KEY=your_resend_api_key
QUIRKIFY_FROM_EMAIL=noreply@yourdomain.com

# --- Mapbox (Public — address autocomplete) ---
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# --- TCG Shipping (Private) ---
TCG_API_KEY=your_tcg_api_key

# --- Admin emails (comma-separated) ---
VITE_ADMIN_EMAILS=admin@example.com

# --- App ---
APP_URL=https://quirkify.co.za
NODE_ENV=production
