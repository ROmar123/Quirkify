rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: id, name, description, category, priceRange (min, max), confidenceScore, imageUrl, status, createdAt, marketData
    //
    // Collection: campaigns
    // Fields: id, title, description, suggestedProducts, status, type, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "patengel85@gmail.com");
    }

    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.authorUid;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.category is string && data.category.size() > 0 &&
             data.stock is number && data.stock > 0 &&
             data.retailPrice is number && data.retailPrice > 0 &&
             data.discountPrice is number && data.discountPrice > 0 &&
             data.markdownPercentage is number && data.markdownPercentage >= 0 && data.markdownPercentage <= 100 &&
             data.condition in ['New', 'Like New', 'Pre-owned', 'Refurbished'] &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.allocations is map &&
             data.allocations.store is number && data.allocations.store >= 0 &&
             data.allocations.auction is number && data.allocations.auction >= 0 &&
             data.allocations.packs is number && data.allocations.packs >= 0 &&
             // CRITICAL: Total allocated cannot exceed total stock
             (data.allocations.store + data.allocations.auction + data.allocations.packs) <= data.stock &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function allocationsValid(data) {
      return (data.allocations.store + data.allocations.auction + data.allocations.packs) <= data.stock;
    }

    function isValidAuction(data) {
      return data.productId is string &&
             data.sellerId is string &&
             data.startPrice is number && data.startPrice > 0 &&
             data.currentBid is number && data.currentBid >= data.startPrice &&
             data.startTime is string &&
             data.endTime is string &&
             timestamp(data.endTime) > timestamp(data.startTime) &&
             data.status in ['active', 'ended', 'cancelled'] &&
             data.bidCount is number &&
             (data.highestBidderId == null || data.highestBidderId is string);
    }

    function getProduct(productId) {
      return get(/databases/$(database)/documents/products/$(productId)).data;
    }

    function isValidUserProfile(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 1000)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000));
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.type in ['outbid', 'won', 'order_update', 'system'] &&
             data.read is bool;
    }

    match /products/{productId} {
      allow read: if true; // Public can see products
      // Create: Authenticated users create new products as pending
      allow create: if isAuthenticated() &&
        isValidProduct(request.resource.data) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.authorUid == request.auth.uid;

      // Update: Admin can change status/reject. Owner can update allocations if pending
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.authorUid == request.auth.uid &&
         isValidProduct(request.resource.data) &&
         request.resource.data.status == resource.data.status && // Cannot change own status
         allocationsValid(request.resource.data)); // Allocations must be valid

      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /auctions/{auctionId} {
      allow read: if true;
      // Create: Admin only, and product must have auction allocation > 0
      allow create: if isAdmin() &&
        isValidAuction(request.resource.data) &&
        request.resource.data.status == 'active' &&
        // CRITICAL: Verify product has auction allocation
        getProduct(request.resource.data.productId).allocations.auction > 0;

      allow update: if isAdmin() || (
        isAuthenticated() && 
        isValidAuction(request.resource.data) && (
          // Case 1: Bidding
          (
            resource.data.status == 'active' &&
            request.resource.data.status == 'active' &&
            request.resource.data.currentBid > resource.data.currentBid &&
            request.resource.data.highestBidderId == request.auth.uid &&
            request.resource.data.bidCount == (resource.data.bidCount || 0) + 1 &&
            request.resource.data.endTime >= resource.data.endTime &&
            // Ensure other fields are unchanged
            request.resource.data.productId == resource.data.productId &&
            request.resource.data.sellerId == resource.data.sellerId &&
            request.resource.data.startPrice == resource.data.startPrice &&
            request.resource.data.startTime == resource.data.startTime
          ) ||
          // Case 2: Concluding (anyone can end it if time has passed)
          (
            resource.data.status == 'active' &&
            request.resource.data.status == 'ended' &&
            request.time >= timestamp(resource.data.endTime) &&
            // Ensure other fields are unchanged during conclusion
            request.resource.data.currentBid == resource.data.currentBid &&
            request.resource.data.highestBidderId == resource.data.highestBidderId &&
            request.resource.data.bidCount == resource.data.bidCount &&
            request.resource.data.endTime == resource.data.endTime &&
            request.resource.data.productId == resource.data.productId &&
            request.resource.data.sellerId == resource.data.sellerId &&
            request.resource.data.startPrice == resource.data.startPrice &&
            request.resource.data.startTime == resource.data.startTime
          )
        )
      );

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
          request.resource.data.bidderId == request.auth.uid &&
          request.resource.data.auctionId == auctionId &&
          request.resource.data.amount == getAfter(/databases/$(database)/documents/auctions/$(auctionId)).data.currentBid;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUserProfile(request.resource.data);
      allow update: if (isAuthenticated() && request.auth.uid == userId && isValidUserProfile(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /live_sessions/{sessionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      
      match /chat/{messageId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text.size() < 500;
      }
    }

    match /user_progress/{uid} {
      allow read: if (isAuthenticated() && request.auth.uid == uid) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if (isAuthenticated() && request.auth.uid == uid) || isAdmin();
    }

    match /users/{userId}/collection/{itemId} {
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /packs/{packId} {
      allow read: if true;
      // Create: Admin only, and linked products must have packs allocation
      allow create: if isAdmin() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.price is number &&
        request.resource.data.price > 0 &&
        request.resource.data.linkedProductIds is list &&
        request.resource.data.linkedProductIds.size() > 0 &&
        // CRITICAL: All linked products must have packs allocation > 0
        request.resource.data.linkedProductIds.all(
          productId, getProduct(productId).allocations.packs > 0
        );

      // Update: Admin only
      allow update: if isAdmin() &&
        // If linkedProductIds changes, verify all have packs allocation
        (!('linkedProductIds' in request.resource.data.diff(resource.data).affectedKeys()) ||
         (request.resource.data.linkedProductIds is list &&
          request.resource.data.linkedProductIds.size() > 0 &&
          request.resource.data.linkedProductIds.all(
            productId, getProduct(productId).allocations.packs > 0
          )
        ));

      allow delete: if isAdmin();
    }
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
